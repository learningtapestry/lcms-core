<form action="<%= admin_appearance_path %>" method="put">
  <div class="form-group">
    <label for="header_bg_color"><%= t("admin.appearance.settings.#{setting_key}") %></label>
    <input type="color" name="header_bg_color" id="header_bg_color" value="<%= setting_value %>">
  </div>
  <button type="submit" class="btn btn-primary"><%= t("admin.appearance.save") %></button>
</form>