<form action="<%= admin_appearance_path %>" method="put">
  <div class="form-group">
    <label for="header_logo"><%= t("admin.appearance.settings.#{setting_key}") %></label>
    <input type="text" name="header_logo" id="header_logo" value="<%= setting_value %>">
  </div>
  <button type="submit" class="btn btn-primary"><%= t("admin.appearance.save") %></button>
</form>