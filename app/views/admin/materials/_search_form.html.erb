<%= simple_form_for :query, url: admin_materials_path, html: { 'data-turbo-track': 'reload', method: :get } do |f| %>
  <div class="row mb-lg-2">
    <div class="col">
      <%= f.input :subject, label: 'Subject', required: false, as: :select, include_blank: true,
                  collection: SUBJECTS.map { |key, val| [key, val] },
                  label_method: :last,
                  value_method: :first %>
    </div>
    <div class="col">
      <%= f.input :grades, collection: GRADES_COLLECTION,
                  input_html: { class: 'selectize', multiple: true },
                  label: t('.grades'), required: false, wrapper: false %>
    </div>
    <div class="col">
      <%= f.input :orientation, label: 'Page Orientation',
                  required: false,
                  as: :select,
                  include_blank: true,
                  collection: %w(landscape portrait),
                  label_method: :upcase,
                  value_method: ->(val) { val[0].downcase } %>
    </div>
    <div class="col">
      <%= f.input :name_date, label: 'Name Date',
                  required: false,
                  as: :select,
                  include_blank: true,
                  collection: [["Yes", "true"], ["No", "false"]] %>
    </div>
    <div class="col">
      <%= f.input :language, label: 'Language',
                  required: false,
                  as: :select,
                  include_blank: true,
                  collection: %w(English Spanish) %>
    </div>
    <div class="col">
      <%= f.input :sort_by,
                  required: false,
                  as: :select,
                  collection: [["Material ID", "identifier"], ["Last update", "last_update"]],
                  include_blank: false,
                  wrapper_html: { class: 'o-admin-sort-by' } %>
    </div>
  </div>
  <div class="row">
    <div class="col">
      <%= f.input :search_term, label: 'Material ID', required: false,
                  placeholder: 'Enter Search Terms' %>
    </div>
    <div class="col">
      <%= f.input :search_file_name, label: 'File Name', required: false,
                  placeholder: 'Enter File Name' %>
    </div>
    <div class="col">
      <%= f.input :material_title, label: 'Material Title', required: false,
                  placeholder: 'Enter Material Title' %>
    </div>
    <div class="col">
      <%= f.input :material_type, label: 'Material Type', required: false,
                  placeholder: 'Enter Material Type' %>
    </div>
    <div class="col">
      <%= f.button :submit, t('admin.common.search'), class: 'btn btn-warning', name: nil %>
    </div>
  </div>
<% end %>
