<%# Recursively renders a settings value tree as typed inputs.
    locals: model (a Setting::Base subclass), node (Hash to render), path (the
    path array within the setting), group (setting key, for the HTML name). %>
<% node.each do |key, value| %>
  <% child_path = path + [key.to_s] %>
  <% if value.is_a?(Hash) %>
    <fieldset class="border rounded p-2 mb-3">
      <legend class="fs-6 fw-semibold"><%= key.to_s.humanize %></legend>
      <%= render partial: "admin/settings/show/form_node", locals: { model: model, node: value, path: child_path, group: group } %>
    </fieldset>
  <% else %>
    <% descriptor = model.field_descriptor(child_path, value) %>
    <% name = group.to_s + child_path.map { |segment| "[#{segment}]" }.join %>
    <% error = model.error_for(child_path) %>
    <div class="row align-items-center mb-2">
      <label class="col-sm-3 col-form-label"><%= key.to_s.humanize %></label>
      <div class="col-sm-9">
        <% case descriptor[:input] %>
        <% when :checkbox %>
          <input type="hidden" name="<%= name %>" value="0" form="settings-form">
          <input type="checkbox" name="<%= name %>" value="1" form="settings-form" class="form-check-input" <%= "checked" if value %>>
        <% when :number %>
          <input type="number" step="1" name="<%= name %>" value="<%= value %>" form="settings-form" class="form-control<%= " is-invalid" if error %>">
        <% when :renderer_select %>
          <select name="<%= name %>" form="settings-form" class="form-select<%= " is-invalid" if error %>">
            <option value=""><%= t("admin.settings.renderer_select.use_fallback") %></option>
            <% available_pdf_renderers.each do |identifier| %>
              <option value="<%= identifier %>" <%= "selected" if value.to_s == identifier.to_s %>><%= identifier %></option>
            <% end %>
          </select>
        <% when :select %>
          <select name="<%= name %>" form="settings-form" class="form-select<%= " is-invalid" if error %>">
            <% descriptor[:options].each do |option| %>
              <option value="<%= option %>" <%= "selected" if value.to_s == option %>><%= option.humanize %></option>
            <% end %>
          </select>
        <% when :list %>
          <textarea name="<%= name %>" form="settings-form" rows="<%= [Array(value).size + 1, 3].max %>" class="form-control font-monospace<%= " is-invalid" if error %>"><%= Array(value).join("\n") %></textarea>
          <small class="text-muted">One entry per line.</small>
        <% else %>
          <input type="text" name="<%= name %>" value="<%= value %>" form="settings-form" class="form-control<%= " is-invalid" if error %>">
        <% end %>
        <% if error %>
          <div class="invalid-feedback d-block"><%= error %></div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
